# Copy to .env and fill in values.
# Database: use config/database.yml (see config/database.yml.example) or set DATABASE_URL here to override.

# App
APP_NAME=MyApp
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# Database (optional override — otherwise uses config/database.yml)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_development

# JWT
JWT_SECRET_KEY=jwt-secret-change-me-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (caching + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
